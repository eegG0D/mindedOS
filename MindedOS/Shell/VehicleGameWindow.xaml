<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MindedOS.Shell.VehicleGameWindow"
        Title="EEG Autonomous Vehicle" Height="760" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#0A0A0A"
        KeyDown="OnKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#141414" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="DriveButton" Content="▶ DRIVE (EEG)" Click="OnToggleDrive" Margin="0,0,8,0"/>
                <Button x:Name="RecButton" Content="● REC RAW EEG" Click="OnToggleRecord" Margin="0,0,8,0"/>
                <Button x:Name="AiMapButton" Content="AI: GENERATE MAP" Click="OnAiMap" Margin="0,0,8,0"/>
                <Button Content="Close (Esc)" Click="OnClose" Margin="0,0,16,0"/>
                <TextBlock x:Name="Hud" Foreground="#39FF14" FontFamily="Consolas" FontSize="14"
                           VerticalAlignment="Center" Text="Press DRIVE — your EEG steers the car."/>
            </StackPanel>
        </Border>

        <Viewbox Grid.Row="1" Stretch="Uniform" Margin="6">
            <Canvas x:Name="GameCanvas" Width="940" Height="600" Background="#1B5E20"/>
        </Viewbox>
    </Grid>
</Window>
